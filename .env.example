# App — generate with: openssl rand -hex 32
NUXT_SESSION_PASSWORD=
NUXT_TOKEN_ENCRYPTION_KEY=

# Google OAuth — for per-user YouTube connection only, not app login
NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=
NUXT_GOOGLE_REDIRECT_URI=http://localhost:3000/api/youtube/callback

# YouTube Data API v3 key — for fetching public playlists without OAuth
NUXT_YOUTUBE_API_KEY=

# Database path (SQLite file)
DATABASE_URL=./data/yt-player.db
